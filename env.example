# ── Required ────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ─────────────────────────────────────────────────────────────────
# Comma-separated channel IDs where the bot responds (blank = all channels)
ALLOWED_CHANNELS=123456789012345678,987654321098765432

# Role name required to use the bot (blank = everyone can use it)
PREMIUM_ROLE=Premium Member
